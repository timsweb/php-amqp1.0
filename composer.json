{
    "name": "php-amqp10/client",
    "description": "Modern PHP AMQP 1.0 client library for RabbitMQ 4.0+",
    "type": "library",
    "license": "Apache-2.0",
    "keywords": ["amqp", "amqp10", "rabbitmq", "messaging", "queue"],
    "homepage": "https://github.com/php-amqp10/client",
    "support": {
        "issues": "https://github.com/php-amqp10/client/issues",
        "source": "https://github.com/php-amqp10/client"
    },
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "AMQP10\\": "src/AMQP10/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AMQP10\\Tests\\": "tests/"
        }
    }
}
