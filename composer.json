{
    "name": "timsweb/php-amqp1.0",
    "description": "Modern PHP AMQP 1.0 client library for RabbitMQ 4.0+",
    "type": "library",
    "license": "MIT",
    "keywords": ["amqp", "amqp10", "rabbitmq", "messaging", "queue"],
    "homepage": "https://github.com/timsweb/php-amqp1.0",
    "support": {
        "issues": "https://github.com/timsweb/php-amqp1.0/issues",
        "source": "https://github.com/timsweb/php-amqp1.0"
    },
    "require": {
        "php": ">=8.2",
        "revolt/event-loop": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.0",
        "laravel/pint": "^1.29",
        "testcontainers/testcontainers": "^0.2"
    },
    "autoload": {
        "psr-4": {
            "AMQP10\\": "src/AMQP10/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AMQP10\\Tests\\": "tests/"
        }
    }
}
